SELECT
    year,
    make,
    model,
    trim,
    body,
    transmission,
    state AS region,
    condition,
    odometer AS mileage,
    color,
    interior,
    seller,

    -- Clean Prices
    CAST(sellingprice AS FLOAT) AS selling_price,
    CAST(mmr AS FLOAT) AS cost_price,

    -- Time Features
    CAST(saledate AS DATE) AS sale_date,
    EXTRACT(YEAR FROM saledate) AS sale_year,
    EXTRACT(MONTH FROM saledate) AS sale_month,
    EXTRACT(QUARTER FROM saledate) AS sale_quarter,

    -- Calculations
    (CAST(sellingprice AS FLOAT)) AS revenue,   -- per car
    (CAST(sellingprice AS FLOAT) - CAST(mmr AS FLOAT)) AS profit,

    ((CAST(sellingprice AS FLOAT) - CAST(mmr AS FLOAT)) 
     / CAST(sellingprice AS FLOAT)) * 100 AS profit_margin,

    -- Profit Category
    CASE 
        WHEN ((sellingprice - mmr) / sellingprice) * 100 > 20 THEN 'High Margin'
        WHEN ((sellingprice - mmr) / sellingprice) * 100 BETWEEN 10 AND 20 THEN 'Medium Margin'
        ELSE 'Low Margin'
    END AS margin_category,

    -- Price Band (extra insight �)
    CASE 
        WHEN sellingprice < 10000 THEN 'Budget'
        WHEN sellingprice BETWEEN 10000 AND 30000 THEN 'Mid Range'
        ELSE 'Premium'
    END AS price_band

FROM workspace.default.bright_car_sales_data
